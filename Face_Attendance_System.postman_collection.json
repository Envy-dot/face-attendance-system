                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"matric_no\": \"24/1001\",\n  \"department\": \"Computer Science\",\n  \"level\": \"100\",\n  \"course\": \"Software Engineering\",\n  \"descriptor\": \"[...array of 128 floats...]\",\n  \"classIds\": [1, 2]\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/users/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete User",
