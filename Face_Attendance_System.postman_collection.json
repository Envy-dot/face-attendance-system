                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/users/9999",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "1"
                            ]
                        }
                    }
                }
            ]
        },
