                        "url": {
                            "raw": "{{base_url}}/attendance",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "attendance"
                            ],
                            "query": [
                                {
                                    "key": "search",
                                    "value": "",
                                    "disabled": true
                                },
                                {
                                    "key": "sessionId",
                                    "value": "1",
                                    "disabled": true
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Mark Attendance",
